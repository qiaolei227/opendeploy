{
  "name": "opendeploy",
  "version": "0.1.0-alpha.1",
  "description": "Open-source AI delivery agent for Kingdee ERP implementation",
  "main": "./out/main/index.js",
  "productName": "OpenDeploy",
  "author": "qiaolei",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "knowledge:manifest": "node --experimental-strip-types scripts/gen-knowledge-manifest.ts",
    "k3cloud:discover": "node --experimental-strip-types scripts/discover-k3cloud-schema.ts",
    "agent:chat": "tsx --tsconfig tsconfig.node.json scripts/agent-chat.ts"
  },
  "dependencies": {
    "eventsource-parser": "^3.0.8",
    "highlight.js": "^11.11.1",
    "i18next": "^26.0.6",
    "js-yaml": "^4.1.1",
    "mssql": "^12.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tar": "^7.5.13",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/mssql": "^12.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "electron": "^41.2.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
